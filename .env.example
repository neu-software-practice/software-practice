# =========================
# NEUHIS integrated deployment
# Copy to .env and edit secrets before running `make deploy`.
# =========================

# --- Public ports on the host ---
FRONTEND_PORT=5173
BACKEND_PORT=8080
MYSQL_PORT=3306
MEDAGENT_PORT=8083

# --- Compose/build ---
COMPOSE_PROJECT_NAME=neuhis
GOPROXY=https://goproxy.cn,direct

# --- Backend service ---
SERVER_ADDR=:8080
SERVER_MODE=debug
JWT_SECRET=change-this-jwt-secret-to-at-least-32-bytes
ADMIN_JWT_SECRET=change-this-admin-secret-to-at-least-32-bytes
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=info
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# The compose file overrides DATABASE_DSN for container-to-container MySQL.
# Keep this value useful for tools that read .env outside compose.
DATABASE_DSN=root:password@tcp(mysql:3306)/neuhis?charset=utf8mb4&parseTime=True&loc=Local

# --- MySQL ---
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=neuhis

# --- medAgent / LLM provider ---
MEDAGENT_MODE=http
MEDAGENT_BASE_URL=http://medagent:8080
MEDAGENT_API_KEY=sk-replace-me
MEDAGENT_PROVIDER=deepseek
MEDAGENT_MODEL=deepseek-chat

# --- Frontend build ---
VITE_API_MODE=http
VITE_API_BASE_URL=/api
VITE_MOCK_DELAY_MS=400
VITE_TIMELINE_POLL_INTERVAL_MS=5000
