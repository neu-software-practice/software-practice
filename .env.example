# =========================
# NEUHIS integrated deployment
# Copy to .env with `make env`, then edit the three secret values before deploy.
# Container-internal addresses stay fixed in compose.yaml; these ports are for
# host access from your browser or curl.
# =========================

# --- Host ports ---
FRONTEND_PORT=5173
BACKEND_PORT=8080
MYSQL_PORT=3306
MEDAGENT_PORT=8083

# --- Compose/build ---
COMPOSE_PROJECT_NAME=neuhis
GOPROXY=https://goproxy.cn,direct

# --- Backend container runtime ---
SERVER_ADDR=:8080
SERVER_MODE=debug
JWT_SECRET=change-this-jwt-secret-to-at-least-32-bytes
ADMIN_JWT_SECRET=change-this-admin-secret-to-at-least-32-bytes
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=info
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# --- MySQL container runtime ---
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=neuhis

# --- medAgent containers ---
MEDAGENT_MODE=http
MEDAGENT_BASE_URL=http://medagent:8080
MEDAGENT_API_KEY=sk-replace-me
MEDAGENT_PROVIDER=deepseek
MEDAGENT_MODEL=deepseek-chat

# --- Frontend build-time variables ---
VITE_API_MODE=http
VITE_API_BASE_URL=/api
VITE_MOCK_DELAY_MS=400
VITE_TIMELINE_POLL_INTERVAL_MS=5000
VITE_CREATE_VISIT_TIMEOUT_MS=10000
